<tool id="opendna_design" name="OpenDNA Inverse Design" version="0.5.0">
  <description>Generate sequences for a backbone using ESM-IF1</description>
  <requirements>
    <requirement type="package" version="0.5.0">opendna</requirement>
  </requirements>
  <command detect_errors="exit_code"><![CDATA[
    python -m opendna.cli.main design --input '$input' --num_candidates $n --output '$output'
  ]]></command>
  <inputs>
    <param name="input" type="data" format="pdb" label="Backbone PDB"/>
    <param name="n" type="integer" value="10" min="1" max="100" label="Number of candidates"/>
  </inputs>
  <outputs>
    <data name="output" format="fasta" label="${tool.name} on ${on_string}"/>
  </outputs>
</tool>
